# Velocity Labs - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE (Required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# STRIPE (Required for payments)
# ===========================================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ===========================================
# TWILIO (Required for SMS)
# ===========================================
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# ANTHROPIC AI (Required for AI features)
# ===========================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ===========================================
# INSTAGRAM (Required for Instagram DMs)
# ===========================================
INSTAGRAM_ACCESS_TOKEN=your-access-token
INSTAGRAM_ACCOUNT_ID=your-account-id
INSTAGRAM_APP_SECRET=your-app-secret
INSTAGRAM_VERIFY_TOKEN=your-verify-token

# ===========================================
# TELEGRAM (Optional - for Telegram bot)
# ===========================================
TELEGRAM_BOT_TOKEN=your-bot-token
# Secret token for webhook verification (set this when calling setWebhook API)
TELEGRAM_WEBHOOK_SECRET=generate-a-random-secret-here

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com
PAYMENT_LINK_SECRET=generate-a-random-secret-here
PAYMENT_LINK_DOMAIN=yourdomain.com

# ===========================================
# OPTIONAL
# ===========================================
# Master access code for admin bypass (leave empty to disable)
MASTER_ACCESS_CODE=

# OpenRouter (alternative AI provider)
OPENROUTER_API_KEY=
